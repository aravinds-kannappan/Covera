# Covera environment variables
#
# Required for the assistant features (natural-language intake + the what-if agent).
# Create a key at https://console.anthropic.com, then copy this file to .env.local
# and paste your real key. .env.local is gitignored.
#
# The optimizer, simulation, charts, and Coverage Card all work without this key —
# only the conversational assistant and voice-to-profile need it.
ANTHROPIC_API_KEY=sk-ant-your-key-here
