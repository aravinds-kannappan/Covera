# Covera environment variables
#
# Everything below is OPTIONAL — Covera degrades gracefully. The optimizer,
# simulation, charts, Coverage Card, and the scripted landing-page demo all work
# with NO keys at all. Each capability lights up as you add the matching keys.

# --- Assistant (natural-language intake + the what-if agent + the texting agent) ---
# Create a key at https://console.anthropic.com, copy this file to .env.local,
# and paste your real key. .env.local is gitignored.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Texting channel ---
# How the agent delivers texts. "sandbox" (default) drives the on-page live demo
# with no external account. "loopmessage" sends real blue-bubble iMessage.
CHANNEL_PROVIDER=sandbox

# Real iMessage via LoopMessage (https://loopmessage.com) — only needed when
# CHANNEL_PROVIDER=loopmessage. Apple has no official iMessage API; LoopMessage is a
# relay. SendBlue works the same way if you prefer it.
LOOPMESSAGE_AUTH_KEY=
LOOPMESSAGE_SECRET_KEY=
LOOPMESSAGE_SENDER_NAME=
# Shared secret used to verify inbound webhook signatures.
LOOP_WEBHOOK_SECRET=

# --- Conversation memory (Upstash Redis, REST) ---
# Texting is stateless between messages, so threads + profiles are stored by phone.
# Without these, an in-process map is used (fine for local/demo; resets on cold start).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Outreach (optional real send to employer HR / hospital) ---
# When unset, the agent still DRAFTS outreach and shows it; it just won't send.
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=

# --- Orthogonal (optional: omnichannel + live data + identity) ---
# One key unlocks several capabilities through the Orthogonal Run API gateway. With this
# key unset, every capability below stays dormant and the app behaves exactly as above.
# Nothing here bills on page load, in the demo, or during a build: a paid call only happens
# on an explicit action. Get a key at Orthogonal, then paste it into .env.local.
ORTHOGONAL_API_KEY=

# Optional soft ceiling on total Orthogonal spend (USD). Once reached, further paid calls are
# refused before spending. Leave blank for no cap. Recommended while testing, e.g. 2.00.
ORTH_MAX_SPEND_USD=

# AgentPhone SMS (and, when enabled, voice). Provision once with:
#   ORTHOGONAL_API_KEY=... tsx scripts/agentphone/setup.ts --webhook https://your-app/api/sms/webhook
# Then paste the printed agent id here and set CHANNEL_PROVIDER=agentphone to route real SMS.
# Sending one SMS bills $0.03; inbound is free.
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
# Optional shared secret to verify inbound AgentPhone webhooks (like LOOP_WEBHOOK_SECRET).
AGENTPHONE_WEBHOOK_SECRET=
# Outbound voice calls are scaffolded but OFF. Set to "true" only when you want to enable
# them; each call then bills $0.10. Leave unset for SMS-only.
ORTH_ENABLE_VOICE=

# ScrapeGraphAI, Tavily, and Didit all ride the same ORTHOGONAL_API_KEY above (no extra keys):
#   - Document link extraction: POST /api/documents with { kind, url } ($0.025/extract).
#   - Live web search: the concierge's web_search tool ($0.01/query, cached).
#   - Email identity verification: /api/verify send + check ($0.04 to send, check is free),
#     which gates real outreach sends on the member's behalf.

# --- Voice concierge + Baseten brain (all on the same ORTHOGONAL_API_KEY above, no extra keys) ---
# The "Talk it through" tab on /patient speaks with the patient and pops up a plan picker. Its
# brain runs on a cheap Baseten chat model through the gateway (falls back to Claude Sonnet 5 when
# Orthogonal is unset), and its voice runs on ElevenLabs. Every paid call fires only on an explicit
# action (recording, or a reply being spoken) and honors ORTH_MAX_SPEND_USD. With nothing set the
# tab still works on the browser's built-in speech and Claude.
#   - Voice reply (TTS):  POST /api/voice/speak      ($0.08, cached per line)
#   - Voice input (STT):  POST /api/voice/transcribe ($0.03)
#   - Concierge brain:    Baseten chat completions via the gateway (~$0.0025 / 4k tokens)

# Baseten model ids (Orthogonal Baseten Model APIs). Defaults are set in code; override here.
# Options include deepseek-ai/DeepSeek-V3.1, zai-org/GLM-4.6, moonshotai/Kimi-K2-Instruct, openai/gpt-oss-120b.
BASETEN_MODEL=deepseek-ai/DeepSeek-V3.1
BASETEN_FAST_MODEL=

# ElevenLabs model + per-agent voice ids (optional; sensible stock defaults are set in code).
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_VOICE_INTAKE=
ELEVENLABS_VOICE_ADVISOR=
ELEVENLABS_VOICE_CLINICAL=
ELEVENLABS_VOICE_EMPLOYER=
ELEVENLABS_VOICE_CONCIERGE=
